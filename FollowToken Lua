-- FollowToken.lua
-- Sistema TTRPG V17: Token de RPG + Party + Skins (Gerenciador)
function onLoad(save_state)
    local myGUID = self.getGUID()
    local oldGUID = self.getMemo()
    if oldGUID ~= "" and oldGUID ~= myGUID then
        Global.call("registerToken", {guid = myGUID, old_guid = oldGUID})
        self.setMemo("")
    else
        Global.call("registerToken", {guid = myGUID})
    end
    
    self.addContextMenuItem("Modo RPG: On/Off", function(p)
        Global.call("toggleFollowCamera", {player_color = p, target_guid = self.getGUID()})
    end)
    
    self.addContextMenuItem("Adicionar à Iniciativa", function()
        Global.call("addIdToInitiative", {guid = self.getGUID()})
    end)
    self.addContextMenuItem("Juntar ao Grupo (Party)", function()
        Global.call("addToParty", {guid = self.getGUID()})
    end)
    self.addContextMenuItem("Separar do Grupo", function()
        Global.call("removeFromParty", {guid = self.getGUID()})
    end)
    self.addContextMenuItem("Adicionar Nova Skin", function(p)
        Global.call("openSkinPanel", {color = p, guid = self.getGUID()})
    end)
    
    self.addContextMenuItem("Gerenciar Skins", function(p)
        Global.call("openSkinManager", {color = p, guid = self.getGUID()})
    end)
end
function prepareMigration()
    self.setMemo(self.getGUID())
end
