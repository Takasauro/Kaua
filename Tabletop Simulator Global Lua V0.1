            <Text text="Nova Skin (Traje Alternativo)" color="#FFCC00" fontSize="16" fontStyle="Bold" alignment="MiddleCenter"/>
            <InputField id="SkinNameInput" placeholder="Nome da Skin (ex: Armadura de Ferro)..." onEndEdit="onEditName" preferredWidth="310" preferredHeight="35"/>
            <InputField id="SkinFrontInput" placeholder="URL ou Imagem Frente..." onEndEdit="onEditFront" preferredWidth="310" preferredHeight="30"/>
            <InputField id="SkinBackInput" placeholder="URL ou Imagem Costas..." onEndEdit="onEditBack" preferredWidth="310" preferredHeight="30"/>
