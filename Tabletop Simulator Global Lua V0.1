-- LOGICA DE SKINS E GERENCIAMENTO
-- =========================================================
function openSkinPanel(params)
    RPG_System.SkinUI.activeFor = params.color
    RPG_System.SkinUI.guid = params.guid
    RPG_System.SkinUI.name = ""
    RPG_System.SkinUI.front = ""
    RPG_System.SkinUI.back = ""
    UI.setAttribute("SkinNameInput", "text", "")
    UI.setAttribute("SkinFrontInput", "text", "")
    UI.setAttribute("SkinBackInput", "text", "")
    UI.setAttribute("SkinPanel", "visibility", params.color)
    UI.setAttribute("SkinPanel", "active", "true")
end
function onEditName(p, v) RPG_System.SkinUI.name = v end
function onEditFront(p, v) RPG_System.SkinUI.front = v end
function onEditBack(p, v) RPG_System.SkinUI.back = v end
function submitAddSkin(player)
    local s = RPG_System.SkinUI
    if player.color ~= s.activeFor then return end
    if not s.name or s.name == "" then s.name = "Skin " .. (RPG_System.SkinData[s.guid] and #RPG_System.SkinData[s.guid].skins + 1 or 2) end
    addSkin({guid = s.guid, name = s.name, front = s.front, back = s.back})
    UI.setAttribute("SkinPanel", "active", "false")
end
function cancelAddSkin() UI.setAttribute("SkinPanel", "active", "false") end
function addSkin(params)
    local guid = params.guid
    if not params.front or params.front == "" then broadcastToAll("Frente obrigatória!", {1,0,0}); return end
    local back = (not params.back or params.back == "") and params.front or params.back
    if not RPG_System.SkinData[guid] then
        local t = getObjectFromGUID(guid)
        if not t then return end
        local cust = t.getCustomObject() or {}
        RPG_System.SkinData[guid] = { skins = {{name="Original", front=cust.image or "", back=cust.image_bottom or ""}}, index = 1 }
    end
    table.insert(RPG_System.SkinData[guid].skins, {name=params.name, front=params.front, back=back})
    broadcastToAll("✨ Skin '".. params.name .."' Salva!", {1, 0.8, 0})
    
    -- Refresh Manager if open
    if UI.getAttribute("SkinManagerPanel", "active") == "true" then
        openSkinManager({color = RPG_System.SkinUI.activeFor, guid = guid})
    end
end
-- Gerenciador de Skins
function openSkinManager(params)
    local guid = params.guid
    if not RPG_System.SkinData[guid] then
        local t = getObjectFromGUID(guid)
        if not t then return end
        local cust = t.getCustomObject() or {}
        RPG_System.SkinData[guid] = { skins = {{name="Original", front=cust.image or "", back=cust.image_bottom or ""}}, index = 1 }
    end
    
    local sd = RPG_System.SkinData[guid]
    local rows = ""
    for i, skin in ipairs(sd.skins) do
        local color = (i == sd.index) and "#33CC33" or "#FFFFFF"
        rows = rows .. [[
        <HorizontalLayout height="40" spacing="10">
            <Text text="]].. i ..[[. ]].. skin.name ..[[" color="]].. color ..[[" fontSize="14" alignment="MiddleLeft" preferredWidth="200"/>
            <Button text="Selecionar" onClick="applySkinFromManager(]].. i ..[[,]].. guid ..[[)" color="#4444AA" preferredWidth="80"/>
            ]] .. (i > 1 and [[<Button text="Excluir" onClick="deleteSkinFromManager(]].. i ..[[,]].. guid ..[[)" color="#AA4444" preferredWidth="60"/>]] or [[<Panel preferredWidth="60"/>]]) .. [[
        </HorizontalLayout>
        ]]
    end
    
    UI.setXmlTable(UI.getXmlTable()) -- Refresh XML state before partial update? Sometimes needed in TTS.
    UI.setXml(UI.getXml():gsub('<VerticalLayout id="SkinListContainer" spacing="5">.-</VerticalLayout>', '<VerticalLayout id="SkinListContainer" spacing="5">'.. rows ..'</VerticalLayout>'))
    
    UI.setAttribute("SkinManagerPanel", "visibility", params.color)
    UI.setAttribute("SkinManagerPanel", "active", "true")
end
function applySkinFromManager(player, index_guid_str)
    -- index_guid_str vem como "index,guid" devido ao limite de argumentos do onClick em XML
    local parts = {}
    for i in string.gmatch(index_guid_str, "[^,]+") do table.insert(parts, i) end
    local index = tonumber(parts[1])
    local guid = parts[2]
    
    local sd = RPG_System.SkinData[guid]
    if not sd or not sd.skins[index] then return end
    
    sd.index = index
    local nSkin = sd.skins[index]
    local t = getObjectFromGUID(guid)
    if t then
        local c = t.getCustomObject() or {}
        c.image, c.image_bottom = nSkin.front, nSkin.back
        t.setCustomObject(c)
        t.call("prepareMigration")
        t.reload()
        broadcastToColor("🎭 Vistindo: " .. nSkin.name, player.color, {0.5, 1, 0.5})
    end
    UI.setAttribute("SkinManagerPanel", "active", "false")
end
function deleteSkinFromManager(player, index_guid_str)
    local parts = {}
    for i in string.gmatch(index_guid_str, "[^,]+") do table.insert(parts, i) end
    local index = tonumber(parts[1])
    local guid = parts[2]
    
    if index == 1 then return end -- Protege original
    
    local sd = RPG_System.SkinData[guid]
    table.remove(sd.skins, index)
    if sd.index >= index and sd.index > 1 then sd.index = sd.index - 1 end
    
    broadcastToColor("🗑️ Skin removida.", player.color, {1, 0.5, 0.5})
    -- Refresh menu
    openSkinManager({color = player.color, guid = guid})
end
function closeSkinManager() UI.setAttribute("SkinManagerPanel", "active", "false") end
function cycleSkin(color)
    local guid = RPG_System.Camera.target_guid
    if not guid then return end
    local sd = RPG_System.SkinData[guid]
    if not sd or #sd.skins <= 1 then return end
    sd.index = sd.index + 1
    if sd.index > #sd.skins then sd.index = 1 end
    local nSkin = sd.skins[sd.index]
    local t = getObjectFromGUID(guid)
    if t then
        local c = t.getCustomObject() or {}
        c.image, c.image_bottom = nSkin.front, nSkin.back
        t.setCustomObject(c)
        t.call("prepareMigration"); t.reload()
        broadcastToColor("🎭 Vestindo: " .. nSkin.name, color, {0.5, 1, 0.5})
    end
end
-- =========================================================
-- COMBATE E MOVIMENTO (V17 - Estável)
-- =========================================================
function toggleCombatMode(player)
    local c = RPG_System.Combat
    if c.active then c.active = false else
        if #c.initiativeList == 0 then return end
        c.active, c.currentTurnIndex, c.currentMovement = true, 1, 0
        forceTurnSwitch(player.color)
    end
    updateUI()
end
function endTurn(player)
    local c = RPG_System.Combat
    if not c.active then return end
    c.currentTurnIndex = c.currentTurnIndex + 1
    if c.currentTurnIndex > #c.initiativeList then c.currentTurnIndex = 1 end
    c.currentMovement = 0
    forceTurnSwitch(player.color); updateUI()
end
function forceTurnSwitch(player_color)
    local guid = RPG_System.Combat.initiativeList[RPG_System.Combat.currentTurnIndex]
    local t = getObjectFromGUID(guid)
    if t then toggleFollowCamera({player_color = player_color, target_guid = guid}, true) end
end
function processMovement()
    local cam = RPG_System.Camera
    if not cam.active or not cam.player_color then return end
    local target = getObjectFromGUID(cam.target_guid)
    if not target then return end
    local keys = RPG_System.KeysPressed[cam.player_color]
    if not keys then return end
    local pos, rot, fwd = target.getPosition(), target.getRotation(), target.getTransformForward()
    local spd, c = RPG_System.MoveConfig.speed, RPG_System.Combat
    local can = (not c.active) or (cam.target_guid == c.initiativeList[c.currentTurnIndex] and c.currentMovement < c.maxMovement)
    local dP, dR = {x=0, y=0, z=0}, 0
    local mP, mR = false, false
    if can then
        if keys[1] then dP.x=dP.x+fwd.x*spd; dP.z=dP.z+fwd.z*spd; mP=true end
        if keys[2] then dP.x=dP.x-fwd.x*spd; dP.z=dP.z-fwd.z*spd; mP=true end
        if keys[6] then dP.y=dP.y+RPG_System.MoveConfig.liftSpeed; mP=true end
    end
    if keys[3] then dR = dR - RPG_System.MoveConfig.rotSpeed; mR=true end
    if keys[4] then dR = dR + RPG_System.MoveConfig.rotSpeed; mR=true end
    if mP then target.setPosition({pos.x + dP.x, pos.y + dP.y, pos.z + dP.z})
        if c.active and c.lastPos then
            local np = target.getPosition()
            c.currentMovement = c.currentMovement + math.sqrt((np.x - c.lastPos.x)^2 + (np.z - c.lastPos.z)^2)
            c.lastPos = np; updateUI()
        end
    elseif c.active then c.lastPos = target.getPosition() end
    if mR then target.setRotation({rot.x, rot.y + dR, rot.z}) end
    if (mP or mR) and #RPG_System.Party > 0 then
        for _, pg in ipairs(RPG_System.Party) do
            if pg ~= cam.target_guid then
                local po = getObjectFromGUID(pg)
                if po then
                    local pP, pR = po.getPosition(), po.getRotation()
                    if mP then po.setPosition({pP.x + dP.x, pP.y + dP.y, pP.z + dP.z}) end
                    if mR then po.setRotation({pR.x, pR.y + dR, pR.z}) end
                end
            end
        end
    end
end
function onScriptingButtonDown(index, player_color)
    local color = tostring(player_color)
    if not RPG_System.KeysPressed[color] then RPG_System.KeysPressed[color] = {} end
    RPG_System.KeysPressed[color][index] = true
    pcall(function()
        if not RPG_System.Combat.active then
            if index == 7 then cycleToken(color, -1) elseif index == 8 then cycleToken(color, 1) end
        else
            if index == 7 then toggleCombatMode({color = color}) elseif index == 8 then endTurn({color = color}) end
        end
        if index == 9 then cycleSkin(color) end 
    end)
end
function onScriptingButtonUp(i, c) if RPG_System.KeysPressed[tostring(c)] then RPG_System.KeysPressed[tostring(c)][i] = false end end
function gameLoop() pcall(processMovement); pcall(updateCameraRPG) end
function updateCameraRPG()
    local cam = RPG_System.Camera
    if not cam.active or not cam.target_guid then return end
    local t = getObjectFromGUID(cam.target_guid)
    local p = Player[cam.player_color]
    if not t or not p or not p.seated then return end
    local pos, rot = t.getPosition(), t.getRotation()
    local rad = math.rad(rot.y)
    local tP = {pos.x + cam.offset.z*math.sin(rad) + cam.offset.x*math.cos(rad), pos.y + cam.offset.y, pos.z + cam.offset.z*math.cos(rad) - cam.offset.x*math.sin(rad)}
    if cam.currentPos[1] == 0 then cam.currentPos = tP end
    for i=1,3 do cam.currentPos[i] = cam.currentPos[i] + (tP[i] - cam.currentPos[i]) * cam.lerpSpeed end
    local dif = rot.y - cam.currentYaw
    if dif > 180 then dif = dif - 360 elseif dif < -180 then dif = dif + 360 end
    cam.currentYaw = cam.currentYaw + dif * cam.lerpSpeed
    p.lookAt({position = cam.currentPos, pitch = cam.pitch, yaw = cam.currentYaw, distance = 0})
end
function cycleToken(color, dir)
    local tk = RPG_System.RegisteredTokens
    if #tk == 0 then return end
    local cI = 1
    for i, g in ipairs(tk) do if g == RPG_System.Camera.target_guid then cI = i; break end end
    local nI = cI + dir
    if nI > #tk then nI = 1 elseif nI < 1 then nI = #tk end
    toggleFollowCamera({player_color = color, target_guid = tk[nI]}, true)
end
function toggleFollowCamera(ps, f)
    local cam = RPG_System.Camera
    if not f and cam.active and cam.target_guid == ps.target_guid then cam.active = false else
        local t = getObjectFromGUID(ps.target_guid)
        if t then cam.active, cam.target_guid, cam.player_color, cam.currentPos, cam.currentYaw = true, ps.target_guid, ps.player_color, t.getPosition(), t.getRotation().y end
    end
end
function addToParty(p) for _, g in ipairs(RPG_System.Party) do if g == p.guid then return end end table.insert(RPG_System.Party, p.guid); broadcastToAll("Agrupado.", {0.5, 0.8, 1}) end
function removeFromParty(p) for i, g in ipairs(RPG_System.Party) do if g == p.guid then table.remove(RPG_System.Party, i); break end end end
function onUpdateMaxMove(p, v) RPG_System.Combat.maxMovement = tonumber(v) or 30 end
function addIdToInitiative(p) table.insert(RPG_System.Combat.initiativeList, p.guid) end
function removeIdFromInitiative(p) for i, g in ipairs(RPG_System.Combat.initiativeList) do if g == p.guid then table.remove(RPG_System.Combat.initiativeList, i); break end end end
function updateMaxMove(p, v) RPG_System.Combat.maxMovement = tonumber(v) or 30 end
