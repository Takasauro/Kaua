        <VerticalLayout padding="10 10 10 10" spacing="5">
            <Text id="TitleTxt" text="Modo Combate: Inativo" color="#AAAAAA" fontSize="14" fontStyle="Bold" alignment="MiddleCenter"/>
            <Text id="ActiveCharTxt" text="Vez de: --" color="#00CCFF" fontSize="12" fontStyle="Bold" alignment="MiddleCenter" active="false"/>
            <HorizontalLayout spacing="5" flexibleHeight="1">
                <Text text="Passos Max:" color="#FFFFFF" fontSize="12" alignment="MiddleRight" preferredWidth="110"/>
                <InputField id="MaxMoveInput" text="30" characterValidation="Integer" onEndEdit="onUpdateMaxMove" preferredWidth="60"/>
