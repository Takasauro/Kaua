-- Global.lua
-- Sistema TTRPG V20: NUCLEO REFINADO (COMBATE + SKINS + PARTY)
if not RPG_System then RPG_System = {} end
-- 1. Estruturas Base
RPG_System.Camera = {
    active = false,
    target_guid = nil,
    player_color = nil,
    offset = {x = 0.7, y = -3, z = 8},
    pitch = 10,
    lerpSpeed = 0.35,
    currentPos = {0,0,0},
    currentYaw = 0
}
RPG_System.MoveConfig = {
    speed = 0.06,
    rotSpeed = 1.2,
    liftSpeed = 0.1
}
RPG_System.RegisteredTokens = {}
RPG_System.KeysPressed = {}
RPG_System.Party = {} 
RPG_System.SkinData = {} -- SkinData[guid] = { skins = {{name, front, back}}, index = 1 }
RPG_System.SkinUI = { activeFor = nil, guid = nil, name = "", front = "", back = "" }
RPG_System.Combat = {
    active = false,
    initiativeList = {},
    currentTurnIndex = 1,
    maxMovement = 30,
    currentMovement = 0,
    lastPos = nil
}
local FollowTokenCode = [[
-- FollowToken.lua
-- Sistema TTRPG V17: Token de RPG + Party + Skins (Gerenciador)
