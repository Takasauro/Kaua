function updateUI()
    local c = RPG_System.Combat
    if c.active then
        local activeGUID = c.initiativeList[c.currentTurnIndex]
        local activeObj = getObjectFromGUID(activeGUID)
        local nameLabel = activeObj and activeObj.getName() or "Misterio"
        
        UI.setAttribute("TitleTxt", "text", "COMBATE")
        UI.setAttribute("ActiveCharTxt", "active", "true")
        UI.setAttribute("ActiveCharTxt", "text", "Vez de: " .. nameLabel)
        UI.setAttribute("EndTurnBtn", "interactable", "true")
        
        local color = c.currentMovement >= c.maxMovement and "#FF5555" or "#55FF55"
        UI.setAttribute("MoveTrackerTxt", "text", string.format("Gasto: %.1f / %d", c.currentMovement, c.maxMovement))
        UI.setAttribute("MoveTrackerTxt", "color", color)
    else
        UI.setAttribute("TitleTxt", "text", "Modo Combate: OFF")
        UI.setAttribute("ActiveCharTxt", "active", "false")
        UI.setAttribute("EndTurnBtn", "interactable", "false")
        UI.setAttribute("MoveTrackerTxt", "text", "Livre")
    end
end
