function onLoad()
    print(">>> Sistema V20: Nucleo RPG Refinado <<<")
    createUIPanels()
    Wait.time(function() pcall(gameLoop) end, 0.02, -1)
end
-- =========================================================
-- SISTEMA DE REGISTRO E MIGRAÇÃO
-- =========================================================
function registerToken(params)
    if not params or not params.guid then return end
    local newGUID = params.guid
    local oldGUID = params.old_guid
    if oldGUID and oldGUID ~= newGUID then migrateGUID(oldGUID, newGUID) end
    for _, guid in ipairs(RPG_System.RegisteredTokens) do if guid == newGUID then return end end
    table.insert(RPG_System.RegisteredTokens, newGUID)
end
function migrateGUID(old, new)
    if RPG_System.Camera.target_guid == old then RPG_System.Camera.target_guid = new end
    for i, g in ipairs(RPG_System.Combat.initiativeList) do if g == old then RPG_System.Combat.initiativeList[i] = new end end
    for i, g in ipairs(RPG_System.Party) do if g == old then RPG_System.Party[i] = new end end
    if RPG_System.SkinData[old] then RPG_System.SkinData[new] = RPG_System.SkinData[old]; RPG_System.SkinData[old] = nil end
    for i, g in ipairs(RPG_System.RegisteredTokens) do if g == old then RPG_System.RegisteredTokens[i] = new; break end end
end
function unregisterToken(params)
    if not params or not params.guid then return end
    for i, guid in ipairs(RPG_System.RegisteredTokens) do if guid == params.guid then table.remove(RPG_System.RegisteredTokens, i); break end end
    removeIdFromInitiative(params)
    removeFromParty(params)
end
